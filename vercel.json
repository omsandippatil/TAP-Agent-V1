{
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python",
      "config": { "includeFiles": ["app/static/**", "app/render/templates/**", "config.yaml"] }
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/app/static/$1" },
    { "src": "/(.*)", "dest": "/app/main.py" }
  ]
}
